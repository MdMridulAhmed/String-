// Problem: 110A - Nearly Lucky Number
// Description: Count digits 4 and 7

#include <stdio.h>

int main(){
    long long n;
    int count=0;

    printf("Enter a number: ");
    scanf("%lld",&n);

    while(n>0){
        int d = n%10;
        if(d==4 || d==7) count++;
        n/=10;
    }

    if(count==4 || count==7)
        printf("YES");
    else
        printf("NO");
}
