// Problem: 112A - Petya and Strings
// Description: Compare two strings ignoring case

#include <stdio.h>
#include <string.h>

int main(){
    char a[100],b[100];
    scanf("%s %s",a,b);

    for(int i=0;a[i];i++){
        if(a[i]>='A'&&a[i]<='Z') a[i]+=32;
        if(b[i]>='A'&&b[i]<='Z') b[i]+=32;
    }

    int res=strcmp(a,b);

    if(res<0) printf("-1");
    else if(res>0) printf("1");
    else printf("0");
}
