// Problem: 339A - Helpful Maths
// Description: Sort numbers in string like 3+2+1

#include <stdio.h>

int main(){
    char s[100];
    int a[100],n=0;

    scanf("%s",s);

    for(int i=0;s[i];i+=2)
        a[n++]=s[i]-'0';

    for(int i=0;i<n;i++){
        for(int j=i+1;j<n;j++){
            if(a[i]>a[j]){
                int t=a[i];
                a[i]=a[j];
                a[j]=t;
            }
        }
    }

    for(int i=0;i<n;i++){
        printf("%d",a[i]);
        if(i<n-1) printf("+");
    }
}
